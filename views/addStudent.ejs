<!-- addStudent.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Add New Student</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Student List App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addStudent">Add new student</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container">
    <br>
    <div class="text-center"><h2>Add New Student</h2></div>
    <br>

    <!-- The name attributes (name, dob, contact, image) must match what the POST route reads from req.body -->
    <form action="/addStudent" method="POST">
      <div class="mb-3 text-center">
        <label for="name" class="form-label">Student Name:</label>
        <input type="text" class="form-control mx-auto" style="max-width: 300px;" id="name" name="name" required>
      </div>

      <div class="mb-3 text-center">
        <label for="dob" class="form-label">D.o.B:</label>
        <input type="date" class="form-control mx-auto" style="max-width: 300px;" id="dob" name="dob" required>
      </div>

      <div class="mb-3 text-center">
        <label for="contact" class="form-label">Contact:</label>
        <input type="text" class="form-control mx-auto" style="max-width: 300px;" id="contact" name="contact" required>
      </div>

      <div class="mb-3 text-center">
        <label for="image" class="form-label">Image:</label>
        <input type="text" class="form-control mx-auto" style="max-width: 300px;" id="image" name="image" required>
      </div>

      <div class="text-center">
        <button type="submit" class="btn btn-primary">Add Student</button>
      </div>
    </form>
  </div>
</body>
</html>
