<!-- editStudent.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Update Student</title>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Student List App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addStudent">Add new student</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">

        <% if (student) { %>
          <%
            // Format the date as YYYY-MM-DD so the <input type="date"> can display it
            const d = new Date(student.dob);
            const dobValue = d.getFullYear() + '-'
              + String(d.getMonth() + 1).padStart(2, '0') + '-'
              + String(d.getDate()).padStart(2, '0');
          %>

          <div class="card shadow">
            <div class="card-header bg-secondary text-white">
              <h3 class="mb-0">Update Student</h3>
            </div>

            <div class="card-body">
              <!-- The name attributes (name, dob, contact, image) must match what the POST route reads from req.body -->
              <form action="/editStudent/<%= student.studentId %>" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="currentImage" value="<%= student.image %>">

                <div class="mb-3">
                  <label for="name" class="form-label">Student Name:</label>
                  <input type="text" class="form-control" id="name" name="name" value="<%= student.name %>" required>
                </div>

                <div class="mb-3">
                  <label for="dob" class="form-label">D.o.B:</label>
                  <input type="date" class="form-control" id="dob" name="dob" value="<%= dobValue %>" required>
                </div>

                <div class="mb-3">
                  <label for="contact" class="form-label">Contact:</label>
                  <input type="text" class="form-control" id="contact" name="contact" value="<%= student.contact %>" maxlength="20" required>
                </div>

                <div class="mb-3">
                  <label for="image" class="form-label">Image:</label>
                  <input type="file" class="form-control" id="image" name="image" accept="image/*">
                </div>

                <div class="mb-3">
                  <label class="form-label">Current Image</label>
                  <div class="text-center">
                    <img src="<%= student.image && student.image.startsWith('http') ? student.image : '/images/' + student.image %>" alt="<%= student.name %>" class="img-fluid rounded border"
                      style="max-height: 200px;">
                  </div>
                </div>

                <div class="d-grid gap-2">
                  <button type="submit" class="btn btn-warning">Update Student</button>
                  <a href="/" class="btn btn-secondary">Cancel</a>
                </div>

              </form>
            </div>
          </div>

        <% } else { %>

          <div class="alert alert-warning text-center">
            <h5>No student found.</h5>
            <a href="/" class="btn btn-secondary mt-3">Back to Home</a>
          </div>

        <% } %>

      </div>
    </div>
  </div>
</body>
</html>
